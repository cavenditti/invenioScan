# ── Required ────────────────────────────────────────────
# A stable JWT secret (min 32 chars). If unset, an ephemeral one is
# generated and all sessions are lost on restart.
# INVSCAN_JWT_SECRET_KEY=put-a-long-random-string-here-at-least-32-chars

# ── Bootstrap admin ─────────────────────────────────────
# Created on first startup if no admin user exists yet.
# If password is omitted a random one is printed to stdout.
# INVSCAN_BOOTSTRAP_ADMIN_USERNAME=admin
# INVSCAN_BOOTSTRAP_ADMIN_PASSWORD=
# INVSCAN_BOOTSTRAP_ADMIN_EMAIL=admin@localhost

# ── Database ────────────────────────────────────────────
# Default: SQLite in current directory. Override for Postgres:
# INVSCAN_DATABASE_URL=postgresql+asyncpg://user:pass@host/dbname
# INVSCAN_DATABASE_URL=sqlite+aiosqlite:////data/shelfscan.db

# ── Public URL ──────────────────────────────────────────
# Used for generating correct upload URLs, cross-app links, and emails.
# Must be the externally-reachable URL (with https in production).
# INVSCAN_PUBLIC_BASE_URL=https://shelfscan.example.com

# ── Cookies / Security ──────────────────────────────────
# Set to false only behind a non-TLS reverse proxy during development.
# INVSCAN_COOKIE_SECURE=true

# ── CORS ────────────────────────────────────────────────
# Comma-separated origins allowed for CORS (Expo dev server, etc.)
# INVSCAN_CORS_ALLOWED_ORIGINS=["http://localhost:8081"]

# ── Uploads ─────────────────────────────────────────────
# INVSCAN_UPLOAD_DIR=/data/uploads

# ── Email (SMTP) ────────────────────────────────────────
# All optional. If smtp_host is unset, email sending is silently skipped.
# INVSCAN_SMTP_HOST=smtp.example.com
# INVSCAN_SMTP_PORT=587
# INVSCAN_SMTP_USERNAME=
# INVSCAN_SMTP_PASSWORD=
# INVSCAN_SMTP_USE_TLS=true
# INVSCAN_EMAIL_FROM=noreply@shelfscan.example.com
# INVSCAN_ADMIN_NOTIFICATION_EMAIL=admin@example.com

# ── ISBN lookup ─────────────────────────────────────────
# INVSCAN_ISBN_LOOKUP_ENABLED=true
# INVSCAN_ISBN_LOOKUP_TIMEOUT_SECONDS=5.0
