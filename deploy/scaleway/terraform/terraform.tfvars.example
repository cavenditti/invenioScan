# Optional when SCW_DEFAULT_PROJECT_ID is already exported.
# project_id = "11111111-1111-1111-1111-111111111111"

region = "fr-par"
zone   = "fr-par-1"

name_prefix = "shelfscan"

# First apply with this set to false to provision the registry, database, and bucket.
deploy_container = false

# Once the image is pushed, either use the suggested_registry_image output or set an explicit value here.
# container_registry_image = "rg.fr-par.scw.cloud/your-namespace/shelfscan:latest"

# Optional custom hostname once DNS is configured.
# container_hostname = "shelfscan.example.com"

container_name            = "web"
container_port            = 8000
container_cpu_limit       = 1024
container_memory_limit    = 2048
container_min_scale       = 0
container_max_scale       = 3
container_timeout_seconds = 300
container_max_concurrency = 80

rdb_engine         = "PostgreSQL-16"
rdb_node_type      = "db-dev-s"
rdb_database_name  = "shelfscan"
rdb_admin_username = "shelfscan_admin"
rdb_app_username   = "shelfscan_app"
rdb_high_availability = false

# Serverless Containers do not use a stable egress IP here, so the default is permissive.
rdb_acl_cidrs = [
  "0.0.0.0/0",
]

object_storage_prefix     = "uploads"
bootstrap_admin_username  = "admin"
bootstrap_admin_email     = "admin@example.com"

tags = ["shelfscan", "production"]